# ── Odoo (1 untuk semua platform) ────────────────────────────────────────────
ODOO_URL=http://localhost:8069
BRIDGE_SECRET=ganti_dengan_random_string_panjang

# ── Bridge server ──────────────────────────────────────────────────────────────
BRIDGE_PORT=3000

# ── Sessions (1 folder besar, subfolder per platform otomatis) ──────────────
SESSIONS_DIR=./sessions

# ── Telegram (https://my.telegram.org) ───────────────────────────────────────
TG_API_ID=1234567
TG_API_HASH=abcdef1234567890

# Telegram fetch history saat connect (opsional)
TG_FETCH_HISTORY=false
TG_HISTORY_LIMIT=200
TG_HISTORY_DELAY_MS=2000

# ── Instagram polling (detik, min 30) ────────────────────────────────────────
IG_POLL_SEC=45

# ── Threads polling ──────────────────────────────────────────────────────────
TH_API_POLL_SEC=120
TH_SCRAPE_POLL_SEC=180

# ── Batch tuning ──────────────────────────────────────────────────────────────
BATCH_SIZE=10
BATCH_FLUSH_MS=3000
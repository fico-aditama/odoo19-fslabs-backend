<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cb_settings_form" model="ir.ui.view">
        <field name="name">cb.settings.form</field>
        <field name="model">cb.settings</field>
        <field name="arch" type="xml">
            <form string="Bridge Settings">
                <header>
                    <button name="action_health_check" type="object" string="🔌 Check Bridge" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group string="Bridge (1 untuk semua platform)">
                            <field name="bridge_url" placeholder="http://localhost:3000"/>
                            <field name="bridge_secret" password="True"/>
                        </group>
                        <group string="Health">
                            <field name="bridge_health" widget="badge"
                                   decoration-success="bridge_health == 'up'"
                                   decoration-danger="bridge_health == 'down'"/>
                            <field name="bridge_accounts"/>
                            <field name="response_ms"/>
                            <field name="last_check"/>
                            <field name="last_error"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_cb_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">cb.settings</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="res_id" ref="cb_settings_singleton"/>
    </record>
</odoo>

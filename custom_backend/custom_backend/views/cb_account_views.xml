<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cb_account_form" model="ir.ui.view">
        <field name="name">cb.account.form</field>
        <field name="model">cb.account</field>
        <field name="arch" type="xml">
            <form string="Account">
                <header>
                    <button name="action_connect" type="object" string="▶ Connect"
                            class="btn-primary"
                            invisible="status in ('connected','connecting','waiting_qr','waiting_code','waiting_password','waiting_challenge')"/>
                    <button name="action_submit_code" type="object" string="✓ Submit Code"
                            class="btn-primary"
                            invisible="status not in ('waiting_code','waiting_challenge')"/>
                    <button name="action_submit_password" type="object" string="✓ Submit Password"
                            class="btn-primary" invisible="status != 'waiting_password'"/>
                    <button name="action_disconnect" type="object" string="■ Disconnect"
                            class="btn-danger" invisible="status == 'disconnected'"/>
                    <button name="action_refresh_log" type="object" string="⟳ Log"
                            class="btn-secondary" invisible="platform == 'email'"/>
                    <button name="action_fetch_email" type="object" string="⬇ Fetch Email"
                            class="btn-secondary" invisible="platform != 'email'"/>
                    <button name="action_resync" type="object" string="🔄 Re-sync"
                            class="btn-secondary"
                            invisible="platform not in ('whatsapp','telegram','email') or status != 'connected'"
                            help="Tarik ulang grup/kontak (kalau ada yang belum kebawa)"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box">
                        <button name="action_view_chats" type="object"
                                class="oe_stat_button" icon="fa-comments">
                            <field name="chat_count" widget="statinfo" string="Chats"/>
                        </button>
                        <button name="action_view_messages" type="object"
                                class="oe_stat_button" icon="fa-envelope">
                            <field name="message_count" widget="statinfo" string="Messages"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="platform"/>
                            <field name="username" readonly="1" invisible="not username"/>
                            <field name="connected_at" readonly="1"/>
                            <field name="last_ping" readonly="1"/>
                            <field name="track_presence" invisible="platform != 'whatsapp'"/>
                            <field name="download_media" invisible="platform != 'whatsapp'"/>
                            <field name="media_max_mb" invisible="platform != 'whatsapp' or not download_media"/>
                            <field name="scrape_profiles" invisible="platform != 'whatsapp'"/>
                        </group>
                        <group string="Credentials">
                            <field name="phone"
                                   invisible="platform not in ('whatsapp','telegram')"
                                   placeholder="+62..."/>
                            <field name="username"
                                   invisible="platform not in ('instagram','threads')"
                                   placeholder="username"/>
                            <field name="password" password="True"
                                   invisible="platform != 'instagram'"/>
                            <field name="token_secret" password="True"
                                   invisible="platform not in ('discord','threads')"
                                   placeholder="Discord token / Threads access token"/>
                            <field name="extra_config"
                                   invisible="platform != 'threads'"
                                   placeholder="api / scrape"/>
                        </group>
                    </group>
                    <group invisible="platform != 'email'">
                        <div class="alert alert-warning" colspan="2">
                            🔒 Email: WAJIB App Password (bukan password utama). Username = alamat email.
                        </div>
                        <group string="IMAP (terima)">
                            <field name="imap_host"/><field name="imap_port"/>
                            <field name="imap_ssl"/><field name="mail_folder"/>
                            <field name="mail_fetch_limit"/>
                        </group>
                        <group string="SMTP (reply)">
                            <field name="smtp_host"/><field name="smtp_port"/>
                            <field name="smtp_tls"/>
                        </group>
                    </group>

                    <!-- QR (WhatsApp) -->
                    <div class="alert alert-info" invisible="status != 'waiting_qr'">
                        <h4>📱 Scan QR (buka WhatsApp → Perangkat Tertaut)</h4>
                        <field name="qr_image" widget="image" readonly="1"
                               options="{'size': [256, 256]}" nolabel="1"/>
                        <p class="text-muted">Scan QR di atas. (Backup: QR juga muncul di terminal bridge.)</p>
                    </div>
                    <!-- OTP/Code -->
                    <div class="alert alert-warning" invisible="status not in ('waiting_code','waiting_challenge')">
                        <h4>📲 Masukkan kode verifikasi</h4>
                        <field name="login_code" placeholder="12345"/>
                        <p class="text-muted">Lalu klik Submit Code.</p>
                    </div>
                    <!-- 2FA -->
                    <div class="alert alert-warning" invisible="status != 'waiting_password'">
                        <h4>🔒 Masukkan 2FA password</h4>
                        <field name="login_password" password="True"/>
                    </div>
                    <div class="alert alert-success" invisible="status != 'connected'">✅ Connected</div>
                    <div class="alert alert-danger" invisible="status != 'auth_failure'">❌ Auth gagal</div>

                    <div class="alert alert-warning"
                         invisible="platform not in ('discord','instagram')">
                        ⚠️ Platform ini berisiko ban — gunakan akun alternatif.
                    </div>

                    <notebook>
                        <page string="Bridge Log">
                            <field name="bridge_log" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cb_account_list" model="ir.ui.view">
        <field name="name">cb.account.list</field>
        <field name="model">cb.account</field>
        <field name="arch" type="xml">
            <list string="Accounts">
                <field name="name"/>
                <field name="platform" widget="badge"/>
                <field name="username"/>
                <field name="phone"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'connected'"
                       decoration-warning="status in ('connecting','waiting_qr','waiting_code','waiting_password','waiting_challenge')"
                       decoration-danger="status == 'auth_failure'"
                       decoration-muted="status == 'disconnected'"/>
                <field name="chat_count"/>
                <field name="message_count"/>
                <field name="last_ping"/>
                <button name="action_connect" type="object" string="Connect"
                        invisible="status != 'disconnected'" class="btn btn-sm btn-primary"/>
                <button name="action_disconnect" type="object" string="Stop"
                        invisible="status == 'disconnected'" class="btn btn-sm btn-danger"/>
            </list>
        </field>
    </record>

    <record id="view_cb_account_search" model="ir.ui.view">
        <field name="name">cb.account.search</field>
        <field name="model">cb.account</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter string="WhatsApp" name="wa" domain="[('platform','=','whatsapp')]"/>
                <filter string="Telegram" name="tg" domain="[('platform','=','telegram')]"/>
                <filter string="Discord" name="dc" domain="[('platform','=','discord')]"/>
                <filter string="Instagram" name="ig" domain="[('platform','=','instagram')]"/>
                <filter string="Threads" name="th" domain="[('platform','=','threads')]"/>
                <separator/>
                <filter string="Connected" name="conn" domain="[('status','=','connected')]"/>
                <group expand="0" string="Group By">
                    <filter string="Platform" name="by_plat" context="{'group_by':'platform'}"/>
                    <filter string="Status" name="by_status" context="{'group_by':'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_cb_account_kanban" model="ir.ui.view">
        <field name="name">cb.account.kanban</field>
        <field name="model">cb.account</field>
        <field name="arch" type="xml">
            <kanban default_group_by="platform" class="o_cb_dash">
                <field name="name"/><field name="platform"/><field name="status"/>
                <field name="username"/><field name="message_count"/><field name="chat_count"/>
                <field name="last_ping"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click p-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <strong><field name="name"/></strong>
                                <span t-if="record.status.raw_value == 'connected'" class="badge text-bg-success">● UP</span>
                                <span t-elif="record.status.raw_value == 'disconnected'" class="badge text-bg-secondary">○ OFF</span>
                                <span t-elif="record.status.raw_value == 'auth_failure'" class="badge text-bg-danger">✕ AUTH</span>
                                <span t-else="" class="badge text-bg-warning">… <field name="status"/></span>
                            </div>
                            <div class="text-muted small mt-1"><field name="username"/></div>
                            <div class="mt-1">
                                <span class="badge text-bg-light"><field name="message_count"/> msg</span>
                                <span class="badge text-bg-light"><field name="chat_count"/> chat</span>
                            </div>
                            <div class="text-muted small mt-1">ping: <field name="last_ping"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_cb_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">cb.account</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_id" ref="view_cb_account_kanban"/>
    </record>

    <record id="action_cb_account" model="ir.actions.act_window">
        <field name="name">Accounts</field>
        <field name="res_model">cb.account</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_cb_account_search"/>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- KB -->
    <record id="view_cb_kb_list" model="ir.ui.view">
        <field name="name">cb.kb.entry.list</field>
        <field name="model">cb.kb.entry</field>
        <field name="arch" type="xml">
            <list string="Knowledge Base" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="keywords"/>
                <field name="content"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="view_cb_kb_form" model="ir.ui.view">
        <field name="name">cb.kb.entry.form</field>
        <field name="model">cb.kb.entry</field>
        <field name="arch" type="xml">
            <form string="KB Entry">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="keywords" placeholder="harga, pricing, biaya"/>
                        <field name="active"/>
                    </group>
                    <group string="Answer / Info">
                        <field name="content" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_cb_kb" model="ir.actions.act_window">
        <field name="name">Knowledge Base</field>
        <field name="res_model">cb.kb.entry</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Rule -->
    <record id="view_cb_autoreply_rule_form" model="ir.ui.view">
        <field name="name">cb.autoreply.rule.form</field>
        <field name="model">cb.autoreply.rule</field>
        <field name="arch" type="xml">
            <form string="Auto-Reply Rule">
                <header>
                    <button name="action_view_logs" type="object" string="View Logs" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="alert alert-warning" role="alert">
                        ⚠️ Mulai dengan <b>Draft Only</b> + <b>Whitelist</b> untuk test aman.
                        Auto Send + All DM = balas otomatis ke banyak orang, hati-hati.
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="account_id"/>
                            <field name="active"/>
                            <field name="mode"/>
                        </group>
                        <group>
                            <field name="scope"/>
                            <field name="reply_groups"/>
                            <field name="group_mention_only" invisible="not reply_groups"/>
                            <field name="max_per_chat_per_day"/>
                        </group>
                    </group>
                    <group string="Whitelist Chats" invisible="scope != 'whitelist'">
                        <field name="chat_ids" nolabel="1" widget="many2many_tags"/>
                    </group>
                    <notebook>
                        <page string="Knowledge Base">
                            <group>
                                <field name="use_kb"/>
                                <field name="fallback_message"
                                       placeholder="Dikirim kalau AI tidak yakin / di luar KB"/>
                            </group>
                            <group string="Guard / System Prompt">
                                <field name="guard_prompt" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Out-of-Office">
                            <group>
                                <field name="ooo_enabled"/>
                                <field name="ooo_from" invisible="not ooo_enabled"/>
                                <field name="ooo_to" invisible="not ooo_enabled"/>
                                <field name="ooo_message" invisible="not ooo_enabled"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_cb_autoreply_rule_list" model="ir.ui.view">
        <field name="name">cb.autoreply.rule.list</field>
        <field name="model">cb.autoreply.rule</field>
        <field name="arch" type="xml">
            <list string="Auto-Reply Rules">
                <field name="name"/>
                <field name="account_id"/>
                <field name="mode" widget="badge"
                       decoration-warning="mode == 'auto_send'"
                       decoration-info="mode == 'draft_only'"/>
                <field name="scope"/>
                <field name="ooo_enabled"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    <record id="action_cb_autoreply_rule" model="ir.actions.act_window">
        <field name="name">Auto-Reply Rules</field>
        <field name="res_model">cb.autoreply.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Log -->
    <record id="view_cb_autoreply_log_list" model="ir.ui.view">
        <field name="name">cb.autoreply.log.list</field>
        <field name="model">cb.autoreply.log</field>
        <field name="arch" type="xml">
            <list string="Auto-Reply Logs" default_order="create_date desc">
                <field name="create_date"/>
                <field name="chat_id"/>
                <field name="incoming_text"/>
                <field name="generated_reply"/>
                <field name="used_kb"/>
                <field name="is_fallback"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'sent'"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'pending'"
                       decoration-danger="state == 'failed'"
                       decoration-muted="state == 'skipped'"/>
                <button name="action_send_now" type="object" string="Send"
                        invisible="state not in ('draft','failed')" class="btn btn-sm btn-primary"/>
            </list>
        </field>
    </record>
    <record id="view_cb_autoreply_log_form" model="ir.ui.view">
        <field name="name">cb.autoreply.log.form</field>
        <field name="model">cb.autoreply.log</field>
        <field name="arch" type="xml">
            <form string="Auto-Reply Log">
                <header>
                    <button name="action_send_now" type="object" string="✓ Send Now"
                            class="btn-primary" invisible="state not in ('draft','failed')"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="rule_id"/>
                            <field name="account_id"/>
                            <field name="chat_id"/>
                        </group>
                        <group>
                            <field name="used_kb"/>
                            <field name="is_fallback"/>
                            <field name="error" invisible="not error"/>
                        </group>
                    </group>
                    <group string="Incoming"><field name="incoming_text" nolabel="1" readonly="1"/></group>
                    <group string="Generated Reply"><field name="generated_reply" nolabel="1"/></group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_cb_autoreply_log" model="ir.actions.act_window">
        <field name="name">Auto-Reply Logs</field>
        <field name="res_model">cb.autoreply.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

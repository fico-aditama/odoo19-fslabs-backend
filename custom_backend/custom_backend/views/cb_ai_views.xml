<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- AI Config -->
    <record id="view_cb_ai_config_form" model="ir.ui.view">
        <field name="name">cb.ai.config.form</field>
        <field name="model">cb.ai.config</field>
        <field name="arch" type="xml">
            <form string="AI Configuration">
                <header>
                    <button name="action_test" type="object" string="🧪 Test LLM" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group string="Provider">
                            <field name="enabled"/>
                            <field name="provider"/>
                            <field name="model_preset"/>
                            <field name="model"
                                   placeholder="gpt-4o-mini / gemini-2.0-flash"/>
                            <field name="api_key" password="True"
                                   invisible="provider == 'custom'"/>
                            <field name="base_url" invisible="provider != 'custom'"
                                   placeholder="https://my-fastapi/ai/chat"/>
                        </group>
                        <group string="Tuning">
                            <field name="temperature"/>
                            <field name="max_tokens"/>
                        </group>
                    </group>
                    <group string="Summary Prompt">
                        <field name="summary_prompt" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_cb_ai_config" model="ir.actions.act_window">
        <field name="name">AI Config</field>
        <field name="res_model">cb.ai.config</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

    <!-- AI Summary -->
    <record id="view_cb_ai_summary_form" model="ir.ui.view">
        <field name="name">cb.ai.summary.form</field>
        <field name="model">cb.ai.summary</field>
        <field name="arch" type="xml">
            <form string="AI Summary">
                <header>
                    <button name="action_generate" type="object"
                            string="✨ Generate Summary" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="scope"/>
                            <field name="date_from" invisible="scope != 'custom'"/>
                            <field name="date_to" invisible="scope != 'custom'"/>
                            <field name="platform_filter"/>
                        </group>
                        <group>
                            <field name="message_count" readonly="1"/>
                            <field name="excluded_count" readonly="1"/>
                            <field name="provider_used" readonly="1"/>
                        </group>
                    </group>
                    <div class="alert alert-info" invisible="excluded_count == 0">
                        🔒 <field name="excluded_count" readonly="1" nolabel="1"/> pesan dari chat privacy di-skip (tidak dikirim ke AI).
                    </div>
                    <group string="Summary">
                        <field name="summary_text" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_cb_ai_summary_list" model="ir.ui.view">
        <field name="name">cb.ai.summary.list</field>
        <field name="model">cb.ai.summary</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="name"/>
                <field name="scope"/>
                <field name="platform_filter"/>
                <field name="message_count"/>
                <field name="excluded_count"/>
                <field name="provider_used"/>
            </list>
        </field>
    </record>
    <record id="action_cb_ai_summary" model="ir.actions.act_window">
        <field name="name">AI Summaries</field>
        <field name="res_model">cb.ai.summary</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'default_scope': 'today'}</field>
    </record>
</odoo>

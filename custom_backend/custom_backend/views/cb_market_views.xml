<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cb_market_list" model="ir.ui.view">
        <field name="name">cb.market.symbol.list</field>
        <field name="model">cb.market.symbol</field>
        <field name="arch" type="xml">
            <list string="Markets" default_order="category, sequence">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="symbol"/>
                <field name="category" widget="badge"/>
                <field name="last_price"/>
                <field name="currency"/>
                <field name="change" decoration-success="change &gt; 0" decoration-danger="change &lt; 0"/>
                <field name="change_pct" decoration-success="change_pct &gt; 0" decoration-danger="change_pct &lt; 0"/>
                <field name="last_update"/>
                <field name="status" widget="badge"
                       decoration-success="status=='ok'" decoration-danger="status=='error'"/>
                <button name="action_refresh" type="object" string="↻" icon="fa-refresh" class="btn btn-sm"/>
            </list>
        </field>
    </record>

    <record id="view_cb_market_form" model="ir.ui.view">
        <field name="name">cb.market.symbol.form</field>
        <field name="model">cb.market.symbol</field>
        <field name="arch" type="xml">
            <form string="Market Symbol">
                <header>
                    <button name="action_refresh" type="object" string="↻ Refresh" class="btn-primary"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="symbol" placeholder="GC=F / USDIDR=X / BBCA.JK"/>
                            <field name="category"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="last_price"/>
                            <field name="currency"/>
                            <field name="change"/>
                            <field name="change_pct"/>
                            <field name="prev_close"/>
                            <field name="last_update"/>
                            <field name="last_error" readonly="1" invisible="not last_error"/>
                        </group>
                    </group>
                    <group string="🔔 Alert to WhatsApp">
                        <field name="alert_enabled"/>
                        <field name="alert_account_id" invisible="not alert_enabled" options="{'no_create': True}"/>
                        <field name="alert_to" invisible="not alert_enabled" placeholder="628xxxx"/>
                        <field name="alert_threshold_pct" invisible="not alert_enabled"/>
                        <field name="last_alert" readonly="1" invisible="not alert_enabled"/>
                    </group>
                    <notebook>
                        <page string="History">
                            <field name="quote_ids">
                                <list default_order="create_date desc">
                                    <field name="create_date"/>
                                    <field name="price"/>
                                    <field name="currency"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cb_market_search" model="ir.ui.view">
        <field name="name">cb.market.symbol.search</field>
        <field name="model">cb.market.symbol</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/><field name="symbol"/>
                <filter string="Gold" name="gold" domain="[('category','=','gold')]"/>
                <filter string="Forex" name="fx" domain="[('category','=','forex')]"/>
                <filter string="Saham ID" name="idx" domain="[('category','=','stock_id')]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="by_cat" context="{'group_by':'category'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_cb_market" model="ir.actions.act_window">
        <field name="name">Markets</field>
        <field name="res_model">cb.market.symbol</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_cb_market_search"/>
    </record>
</odoo>
